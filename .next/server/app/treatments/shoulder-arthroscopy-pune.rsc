pune\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is shoulder arthroscopy used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Shoulder arthroscopy treats rotator cuff tears, shoulder impingement, labral tears, shoulder instability (Bankart lesions), and frozen shoulder.\"}},{\"@type\":\"Question\",\"name\":\"How long does recovery take after shoulder arthroscopy?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Recovery depends on the procedure. Impingement decompression may take 4–6 weeks. Rotator cuff repair typically requires 4–6 months for full recovery.\"}},{\"@type\":\"Question\",\"name\":\"Can I avoid shoulder surgery?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Many shoulder conditions can be managed non-surgically with physiotherapy, activity modification, and injections. Surgery is recommended when conservative treatment fails or for complete tears.\"}}]}"}}],["$","div",null,{"className":"min-h-screen pt-20","children":[["$","section",null,{"className":"section-padding bg-gradient-to-br from-secondary to-secondary-400 text-white","children":["$","div",null,{"className":"container-custom max-w-5xl mx-auto","children":[["$","nav",null,{"className":"flex items-center gap-1.5 text-sm text-neutral-300 mb-6","children":[["$","$L6",null,{"href":"/","className":"hover:text-white transition-colors","children":"Home"}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-right w-3.5 h-3.5","children":[["$","path","mthhwq",{"d":"m9 18 6-6-6-6"}],"$undefined"]}],["$","$L6",null,{"href":"/treatments","className":"hover:text-white transition-colors","children":"Treatments"}],["$","s